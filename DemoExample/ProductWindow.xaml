<Window x:Class="DemoExample.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExample"
        mc:Ignorable="d"
        Icon="/Res/Icon.ico"
        Title="Продукты" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Name="AdminPanel" HorizontalAlignment="Left" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20" Grid.Column="0">
                <TextBlock Text="Поиск"/>
                <TextBox Name="SearchingTextBox" Width="200" TextChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="1">
                <TextBlock Text="Сортировка"/>
                <ComboBox Name="SortingComboBox" Width="200" SelectionChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="2">
                <TextBlock Text="Фильтация"/>
                <ComboBox Name="FilteringComboBox" Width="200" SelectionChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="3">
                <Button x:Name="OrderButton" Click="OrderButton_Click" Height="53" Content="Панель Заказов" Width="145"/>
            </StackPanel>
        </Grid>

        <TextBlock Name="FullUserName" 
                   VerticalAlignment="Top" 
                   HorizontalAlignment="Right" 
                   Margin="20 10"/>


        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10"
                                Tag="{Binding id}"
                                Background="{Binding Background}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Фото -->
                                <Image Width="80" Height="80" Margin="10" Source="{Binding Photo}"/>

                                <!-- Информация о товаре -->
                                <StackPanel Grid.Column="1" Margin="10">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.name}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Producer.name}"/>
                                    <TextBlock Text="{Binding Provider.name}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Price, StringFormat=C2}"/>
                                        <TextBlock Text="{Binding Unit.name}"/>
                                        <TextBlock Text="{Binding StockQuantity}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Кнопки -->
                                <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="15,0,10,0">
                                    <Button Content="Удалить"
                                            Width="85"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            Click="DeleteButton_Click"
                                            Tag="{Binding id}"/>

                                    <Button Content="Редактировать"
                                            Width="105"
                                            Height="32"
                                            Click="EditButton_Click"
                                            Tag="{Binding id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Content="Создать"
                Grid.Row="2"
                Name="CreateButton"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="20 0"
                Click="CreateButton_Click"
                Visibility="Visible"/>

        <Button Content="Выйти"
                Grid.Row="2"
                Name="LogOutButton"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="20 0"
                Click="LogOutButton_Click"/>


    </Grid>
</Window>
