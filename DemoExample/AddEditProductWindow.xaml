<Window x:Class="DemoExample.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExample"
        mc:Ignorable="d"
        Icon="/Res/Icon.ico"
        Title="Добавление и редактирование" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel Margin="20">
                <TextBlock Text="Артикул"/>
                <TextBox x:Name="ProductArticle" MaxLength="10"/>

                <TextBlock Text="Наименование"/>
                <TextBox x:Name="ProductName" MaxLength="30"/>

                <TextBlock Text="Единица измерения"/>
                <ComboBox x:Name="ProductUnit"/>

                <TextBlock Text="Цена"/>
                <TextBox x:Name="ProductPrice"/>

                <TextBlock Text="Производитель"/>
                <ComboBox x:Name="ProductProducer"/>

                <TextBlock Text="Поставщик"/>
                <ComboBox x:Name="ProductProvider"/>

                <TextBlock Text="Категория"/>
                <ComboBox x:Name="ProductCategory"/>

                <TextBlock Text="Скидка"/>
                <TextBox x:Name="ProductDiscount"/>

                <TextBlock Text="Количество на складе"/>
                <TextBox x:Name="ProductStockQuantuty"/>

                <TextBlock Text="Описание"/>
                <TextBox x:Name="ProductDesc" TextWrapping="Wrap" Height="150"/>

                <TextBlock Text="Фото"/>
                <TextBox x:Name="ProductPhoto"/>

            </StackPanel>
        </ScrollViewer>

        <Button x:Name="SaveButton"
                Grid.Row="1"
                Margin="20 0"
                Content="Сохранить"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="SaveButton_Click"/>

        <Button x:Name="CancelButton"
                Grid.Row="1"
                Margin="20 0"
                Content="Отменить"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="CancelButton_Click"/>

        <Button x:Name="DeleteButton"
                Grid.Row="1"
                Margin="20 0"
                Content="Удалить"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="DeleteButton_Click"/>

    </Grid>
</Window>
