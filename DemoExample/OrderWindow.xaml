<Window x:Class="DemoExample.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExample"
        mc:Ignorable="d"
        Icon="/Res/Icon.ico"
        Title="Добавление/Редактирование заказы" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid Name="AdminPanelOrder" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20" Grid.Column="0">
                <TextBlock Text="Поиск"/>
                <TextBox Name="SearchingTextBox" TextChanged="FilterChanged" Width="200"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="1">
                <TextBlock Text="Сортировка"/>
                <ComboBox Name="SortingComboBox" SelectionChanged="FilterChanged" Width="200"/>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="2">
                <TextBlock Text="Фильтрация"/>
                <ComboBox Name="FilteringComboBox" SelectionChanged="FilterChanged" Width="200"/>
            </StackPanel>
        </Grid>

        <TextBlock Name="FullUserName" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="OrderList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Tag="{Binding id}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding OrderDate}"/>
                                        <Run/>
                                        <Run Text="{Binding OrderDelivery}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding PickUpPoint.City}"/>
                                    <TextBlock Text="{Binding PickUpPoint.Street}"/>
                                    <TextBlock Text="{Binding PickUpPoint.House}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" 
                Content="Выйти" 
                Name="BackButton" 
                Click="BackButton_Click" 
                Margin="20 0"
                VerticalAlignment="Center" 
                HorizontalAlignment="Left"/>

        <Button Grid.Row="2"
                Content="Создать"
                Name="CreateButton"
                Click="CreateButton_Click"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="20 0"
                Visibility="Collapsed"/>

    </Grid>
</Window>
